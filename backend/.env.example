# One of these is required
OPENAI_API_KEY=sk-...

# Optional — enables the web-search fallback node
TAVILY_API_KEY=

# Optional — recommended for Hugging Face Spaces since the container disk is
# not persistent across restarts/rebuilds. Leave blank to use embedded Qdrant
# (data written to ./qdrant_db inside the container).
QDRANT_URL=
QDRANT_API_KEY=

# Optional overrides — defaults match the notebook
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
VISION_MODEL=gpt-4o-mini
EMBEDDING_DIM=1536
QDRANT_COLLECTION=agentic_rag_openai
MAX_RETRIES=3
